{% comment %}
  BURANSHH — Product Card Placeholder
  Shown when a collection has no real products yet (store setup phase)
  Usage: {% render 'product-card-placeholder', index: 1 %}
{% endcomment %}

{%- liquid
  assign names = 'Forest Wrap Kurta|Sage Linen Set|Bark Cotton Dress|Parchment Co-ord|Moss Block Print Top|Himalaya Wrap Dress|Buransh Embroidered Kurta|Everyday Linen Shirt' | split: '|'
  assign prices = '2400|3200|2800|3600|1900|4200|3800|2600' | split: '|'
  assign name_idx = index | minus: 1 | modulo: 8
  assign price_idx = index | minus: 1 | modulo: 8
  assign card_name = names[name_idx]
  assign card_price = prices[price_idx]
-%}

<article class="product-card" role="listitem" aria-label="{{ card_name }} — sample product">
  <div class="product-card__image-wrap">
    {%- if index == 1 -%}
      <span class="product-card__badge product-card__badge--forest">New</span>
    {%- elsif index == 3 -%}
      <span class="product-card__badge product-card__badge--red">Sale</span>
    {%- endif -%}

    <div class="product-card__image-placeholder" style="background: {% cycle '#F0EDD0', '#E8E5C8', '#EDE9C9' %};">
      <svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
        <rect x="8" y="8" width="32" height="32" rx="2" stroke="#676A26" stroke-width="1"/>
        <circle cx="24" cy="24" r="6" stroke="#676A26" stroke-width="1"/>
        <path d="M24 14C24 14 27 18 24 21C21 18 24 14 24 14Z" fill="#676A26" opacity="0.4"/>
        <path d="M24 34C24 34 27 30 24 27C21 30 24 34 24 34Z" fill="#676A26" opacity="0.4"/>
      </svg>
    </div>

    <div class="product-card__actions" aria-hidden="true">
      <button class="product-card__action-btn product-card__action-btn--atc" tabindex="-1">Add to Bag</button>
      <button class="product-card__action-btn product-card__action-btn--wish" tabindex="-1">♡ Save</button>
    </div>
  </div>

  <div class="product-card__info">
    <p class="product-card__meta">Buranshh</p>
    <h3 class="product-card__name">{{ card_name }}</h3>
    <div class="product-card__price">
      <span class="product-card__price-current">₹{{ card_price }}</span>
      {%- if index == 3 -%}
        <span class="product-card__price-original">₹{{ card_price | plus: 800 }}</span>
      {%- endif -%}
    </div>
  </div>
</article>
