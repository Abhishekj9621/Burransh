{% comment %}
  BURANSHH — Cart Drawer Snippet
  Slide-out cart, included once in theme.liquid
{% endcomment %}

<div class="cart-drawer" id="CartDrawer" role="dialog" aria-modal="true" aria-label="Shopping cart">
  <div class="cart-drawer-overlay"></div>

  <div class="cart-drawer-panel">
    <div class="cart-drawer__header">
      <div>
        <h2 class="cart-drawer__title">Your Bag</h2>
        <p class="cart-drawer__count">{{ cart.item_count }} item{% if cart.item_count != 1 %}s{% endif %}</p>
      </div>
      <button class="cart-drawer-close" aria-label="Close cart">
        <svg viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.2" xmlns="http://www.w3.org/2000/svg">
          <path d="M2 2l14 14M16 2L2 16"/>
        </svg>
      </button>
    </div>

    <div class="cart-drawer__items">
      {%- if cart.item_count == 0 -%}
        <div style="text-align:center;padding:60px 20px;">
          <p style="font-family:var(--font-serif);font-size:18px;font-style:italic;color:var(--color-text-muted);margin-bottom:20px;">
            Your bag is feeling light.
          </p>
          <a href="{{ routes.all_products_collection_url }}" class="btn btn--outline">Start Shopping</a>
        </div>
      {%- else -%}
        {%- for item in cart.items -%}
          <div class="cart-item" data-line="{{ forloop.index }}">
            <div class="cart-item__image">
              {%- if item.image -%}
                {%- assign item_alt = item.title | escape -%}
                {{ item.image | image_url: width: 200 | image_tag: loading: 'lazy', alt: item_alt }}
              {%- endif -%}
            </div>
            <div class="cart-item__details">
              <h3 class="cart-item__name">{{ item.product.title }}</h3>
              {%- if item.variant.title != 'Default Title' -%}
                <p class="cart-item__variant">{{ item.variant.title }}</p>
              {%- endif -%}
              <p class="cart-item__price">{{ item.final_line_price | money }}</p>
              <div class="cart-item__qty">
                <button class="cart-item__qty-btn" data-qty="{{ forloop.index }}" data-delta="down" aria-label="Decrease quantity">−</button>
                <span class="cart-item__qty-num">{{ item.quantity }}</span>
                <button class="cart-item__qty-btn" data-qty="{{ forloop.index }}" data-delta="up" aria-label="Increase quantity">+</button>
                <button class="cart-item__remove" data-cart-remove="{{ forloop.index }}">Remove</button>
              </div>
            </div>
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>

    {%- if cart.item_count > 0 -%}
      <div class="cart-drawer__footer">
        <div class="cart-drawer__subtotal">
          <span class="cart-drawer__subtotal-label">Subtotal</span>
          <span class="cart-drawer__subtotal-amount">{{ cart.total_price | money }}</span>
        </div>
        <p class="cart-drawer__shipping-note">
          {%- if cart.total_price >= 199900 -%}
            ✓ You've unlocked free shipping
          {%- else -%}
            Add {{ 199900 | minus: cart.total_price | money }} more for free shipping
          {%- endif -%}
        </p>
        <a href="{{ routes.cart_url }}" class="cart-drawer__checkout">Checkout</a>
        <button class="cart-drawer__continue cart-drawer-close">Continue Shopping</button>
      </div>
    {%- endif -%}
  </div>
</div>
