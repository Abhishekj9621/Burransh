{% comment %}
  BURANSHH — Mobile Navigation Drawer Snippet
{% endcomment %}

{%- assign mobile_menu = linklists.main-menu -%}

<div class="mobile-nav-drawer" id="mobile-nav" role="dialog" aria-modal="true" aria-label="Site navigation">
  <div class="mobile-nav-overlay"></div>

  <nav class="mobile-nav-panel">
    <div class="mobile-nav-header">
      <span style="font-family:var(--font-serif);font-size:20px;letter-spacing:0.1em;color:var(--color-bark);">Menu</span>
      <button class="mobile-nav-close" aria-label="Close menu">
        <svg viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.2" xmlns="http://www.w3.org/2000/svg">
          <path d="M2 2l14 14M16 2L2 16"/>
        </svg>
      </button>
    </div>

    <div class="mobile-nav-links">
      {%- if mobile_menu != blank -%}
        {%- for link in mobile_menu.links -%}
          <a href="{{ link.url }}" class="mobile-nav-link">{{ link.title }}</a>
        {%- endfor -%}
      {%- else -%}
        <a href="{{ routes.all_products_collection_url }}" class="mobile-nav-link">Shop All</a>
        <a href="/collections/new-arrivals" class="mobile-nav-link">New Arrivals</a>
        <a href="/pages/about" class="mobile-nav-link">Our Story</a>
        <a href="/pages/contact" class="mobile-nav-link">Contact</a>
      {%- endif -%}
    </div>

    <div style="margin-top:auto;padding-top:32px;border-top:0.5px solid rgba(103,106,38,0.1);display:flex;flex-direction:column;gap:16px;">
      <a href="{{ routes.account_url }}" class="mobile-nav-link" style="font-size:14px;font-family:var(--font-sans);letter-spacing:0.1em;text-transform:uppercase;">Account</a>
      <a href="{{ routes.search_url }}" class="mobile-nav-link" style="font-size:14px;font-family:var(--font-sans);letter-spacing:0.1em;text-transform:uppercase;">Search</a>
    </div>
  </nav>
</div>
