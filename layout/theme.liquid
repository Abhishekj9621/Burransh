<!doctype html>
<html class="no-js" lang="{{ request.locale.iso_code }}">

<head>

  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">

  <title>
    {{ page_title }}
    {% if current_tags %}
      — {{ current_tags | join: ', ' }}
    {% endif %}
    {% unless page_title contains shop.name %}
      — {{ shop.name }}
    {% endunless %}
  </title>

  {% if page_description %}
    <meta name="description" content="{{ page_description | escape }}">
  {% endif %}

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

  <link
    href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;500&family=Jost:wght@300;400;500&display=swap"
    rel="stylesheet">

  {{ 'theme.css' | asset_url | stylesheet_tag }}
  {{ 'buranshh-home.css' | asset_url | stylesheet_tag }}

  {{ content_for_header }}

</head>

<body
  class="template-{{ template.name }}{% if template.suffix %} template-{{ template.name }}--{{ template.suffix }}{% endif %}">

  {%- render 'cart-drawer' -%}
  {%- render 'mobile-nav-drawer' -%}

  {%- sections 'header-group' -%}

  <main
    id="MainContent"
    class="main-content"
    role="main"
    tabindex="-1">

    {{ content_for_layout }}

  </main>

  {%- sections 'footer-group' -%}

  <script>
    window.buranshh = window.buranshh || {};

    window.buranshh.shop = {
      moneyFormat: {{ shop.money_format | json }},
      cartToken: {{ cart.token | json }},
      locale: {{ request.locale.iso_code | json }}
    };
  </script>

  {{ 'theme.js' | asset_url | script_tag }}

</body>
</html>