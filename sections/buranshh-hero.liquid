<section class="buranshh-hero">

  <div class="buranshh-hero__image">
    {% if section.settings.hero_image %}
      {{
        section.settings.hero_image
        | image_url: width: 2400
        | image_tag:
        loading: 'eager',
        class: 'hero-image'
      }}
    {% endif %}
  </div>

  <div class="buranshh-hero__overlay"></div>

  <div class="buranshh-hero__content">

    <p class="hero-eyebrow">
      Rooted in Culture
    </p>

    <h1 class="hero-title">
      {{ section.settings.heading }}
    </h1>

    <p class="hero-subtitle">
      {{ section.settings.subheading }}
    </p>

    <div class="hero-buttons">

      <a href="{{ section.settings.button_link }}"
         class="hero-btn">
        {{ section.settings.button_label }}
      </a>

    </div>

  </div>

</section>

{% schema %}
{
  "name": "Buranshh Hero",
  "settings": [
    {
      "type":"image_picker",
      "id":"hero_image",
      "label":"Hero Image"
    },
    {
      "type":"text",
      "id":"heading",
      "label":"Heading",
      "default":"Bloom In Your Own Season"
    },
    {
      "type":"textarea",
      "id":"subheading",
      "label":"Sub Heading",
      "default":"Handcrafted clothing inspired by culture, nature and everyday elegance."
    },
    {
      "type":"text",
      "id":"button_label",
      "label":"Button Label",
      "default":"Explore Collection"
    },
    {
      "type":"url",
      "id":"button_link",
      "label":"Button Link"
    }
  ],
  "presets":[
    {
      "name":"Buranshh Hero"
    }
  ]
}
{% endschema %}