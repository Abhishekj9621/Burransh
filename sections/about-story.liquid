<section class="about-story">

  <div class="container">

    <div class="brand-story__inner">

      <div>

        <div class="section-label">
          {{ section.settings.label }}
        </div>

        <h2>
          {{ section.settings.heading }}
        </h2>

        <div>
          {{ section.settings.description }}
        </div>

      </div>

      <div>

        {% if section.settings.image %}
          {{
            section.settings.image
            | image_url: width: 1000
            | image_tag: loading: 'lazy'
          }}
        {% endif %}

      </div>

    </div>

  </div>

</section>

{% schema %}
{
  "name": "About Story",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Label",
      "default": "The Name"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "A wildflower from the Himalayas"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    }
  ],
  "presets": [
    {
      "name": "About Story"
    }
  ]
}
{% endschema %}