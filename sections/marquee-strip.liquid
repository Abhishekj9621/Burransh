{% comment %}
  BURANSHH — Marquee Strip Section
  Scrolling text band on forest green background
{% endcomment %}

<div class="marquee-strip" aria-hidden="true" role="presentation">
  <div class="marquee-strip__track">
    {%- for i in (1..4) -%}
      {%- for block in section.blocks -%}
        {%- if block.type == 'item' -%}
          <div class="marquee-strip__item" {{ block.shopify_attributes }}>
            <span class="marquee-strip__text">{{ block.settings.text }}</span>
            <span class="marquee-strip__dot"></span>
          </div>
        {%- endif -%}
      {%- endfor -%}
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "Marquee Strip",
  "tag": "div",
  "max_blocks": 8,
  "settings": [],
  "blocks": [
    {
      "type": "item",
      "name": "Marquee item",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Made slowly. Made to last."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Marquee Strip",
      "blocks": [
        { "type": "item", "settings": { "text": "Made slowly. Made to last." } },
        { "type": "item", "settings": { "text": "Rooted in culture. Worn every day." } },
        { "type": "item", "settings": { "text": "Hand-stitched with care." } },
        { "type": "item", "settings": { "text": "Every thread, chosen with intention." } },
        { "type": "item", "settings": { "text": "Bloom in your own season." } },
        { "type": "item", "settings": { "text": "Himalayan craft for modern life." } }
      ]
    }
  ]
}
{% endschema %}
