{% comment %}
  BURANSHH — Generic Page Section (for policy pages, contact, etc.)
{% endcomment %}

<section style="padding: var(--space-lg) 0 var(--space-xl);">
  <div class="container" style="max-width:760px;">
    <div class="section-label">{{ section.settings.label | default: 'Information' }}</div>
    <h1 style="font-family:var(--font-serif);font-size:clamp(34px,5vw,56px);font-weight:300;color:var(--color-bark);margin-bottom:32px;line-height:1.1;">
      {{ page.title }}
    </h1>
    <div style="font-size:14px;color:var(--color-text-muted);line-height:1.95;">
      {{ page.content }}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Page",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Eyebrow label",
      "default": "Information"
    }
  ]
}
{% endschema %}
