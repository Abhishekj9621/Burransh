{{ 'announcement-bar.css' | asset_url | stylesheet_tag }}

<section
  class="announcement-bar"
  style="
    background: {{ section.settings.background }};
    color: {{ section.settings.text_color }};
    --announcement-height: {{ section.settings.height }}px;
    --announcement-font-size: {{ section.settings.font_size }}px;

    {% if section.settings.show_border %}
      border-bottom: 1px solid rgba(255,255,255,.12);
    {% endif %}
  "
>

  <div class="announcement-bar__container">

    <div class="announcement-bar__inner">

      {% if section.settings.show_lines %}
        <span class="announcement-bar__line"></span>
      {% endif %}

      {% if section.settings.show_icon %}
        <span class="announcement-bar__icon">
          ✦
        </span>
      {% endif %}

      <div class="announcement-bar__text">

        <span class="announcement-desktop">
          {{ section.settings.text }}
        </span>

        <span class="announcement-mobile">

          {% if section.settings.mobile_text != blank %}
            {{ section.settings.mobile_text }}
          {% else %}
            {{ section.settings.text }}
          {% endif %}

        </span>

      </div>

      {% if section.settings.show_icon %}
        <span class="announcement-bar__icon">
          ✦
        </span>
      {% endif %}

      {% if section.settings.show_lines %}
        <span class="announcement-bar__line"></span>
      {% endif %}

    </div>

  </div>

</section>

{% schema %}
{
  "name": "Announcement Bar",
  "settings": [
    {
      "type": "text",
      "id": "text",
      "label": "Desktop Text",
      "default": "Rooted In Culture • Worn Every Day"
    },
    {
      "type": "text",
      "id": "mobile_text",
      "label": "Mobile Text",
      "default": "Rooted In Culture"
    },
    {
      "type": "color",
      "id": "background",
      "label": "Background Color",
      "default": "#676A26"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#F0EDD0"
    },
    {
      "type": "range",
      "id": "height",
      "label": "Height",
      "min": 32,
      "max": 60,
      "step": 2,
      "default": 40
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "Font Size",
      "min": 9,
      "max": 16,
      "step": 1,
      "default": 11
    },
    {
      "type": "checkbox",
      "id": "show_icon",
      "label": "Show Decorative Icons",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_lines",
      "label": "Show Decorative Lines",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_border",
      "label": "Show Bottom Border",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Announcement Bar"
    }
  ]
}
{% endschema %}