{{ 'announcement-bar.css' | asset_url | stylesheet_tag }}

<script src="{{ 'announcement-bar.js' | asset_url }}" defer></script>

{% liquid
assign now_timestamp = 'now' | date: '%s'
assign start_timestamp = section.settings.start_date | date: '%s'
assign end_timestamp = section.settings.end_date | date: '%s'

assign show_section = true

if section.settings.start_date != blank and now_timestamp < start_timestamp
assign show_section = false
endif

if section.settings.end_date != blank and now_timestamp > end_timestamp
assign show_section = false
endif
%}

{% if show_section %}

<section
  id="announcement-bar-{{ section.id }}"
  class="ab {% if section.settings.sticky %}ab--sticky{% endif %}"
  data-announcement-bar
  data-animation="{{ section.settings.animation_style }}"
  data-autoplay="{{ section.settings.enable_autorotate }}"
  data-interval="{{ section.settings.rotate_interval }}"
  style="
    --ab-height-desktop: {{ section.settings.height_desktop }}px;
    --ab-height-mobile: {{ section.settings.height_mobile }}px;

--ab-padding-desktop: {{ section.settings.padding_desktop }}px;
--ab-padding-mobile: {{ section.settings.padding_mobile }}px;

--ab-font-size-desktop: {{ section.settings.font_size_desktop }}px;
--ab-font-size-mobile: {{ section.settings.font_size_mobile }}px;

--ab-link: {{ section.settings.link_color }};

background: {{ section.settings.background_color }};
color: {{ section.settings.text_color }};

"

>

{% if section.settings.enable_desktop == false %} <style>
@media(min-width:769px){
#announcement-bar-{{ section.id }}{
display:none;
}
} </style>
{% endif %}

{% if section.settings.enable_mobile == false %} <style>
@media(max-width:768px){
#announcement-bar-{{ section.id }}{
display:none;
}
} </style>
{% endif %}

  <div class="ab__container">
<div class="ab__inner">

  {% if section.settings.animation_style == 'marquee' %}

    <div class="ab__marquee">

      {% for repeat in (1..6) %}

        {% for block in section.blocks %}

          <div class="ab__marquee-item">

            {% if section.settings.show_icon %}
              <span class="ab__icon">
                {{ section.settings.icon }}
              </span>
            {% endif %}

            <div class="ab__text">
              {{ block.settings.text }}
            </div>

          </div>

        {% endfor %}

      {% endfor %}

    </div>

  {% else %}

    <div class="ab__slider">

      {% for block in section.blocks %}

        <div
          class="ab__slide {% if forloop.first %}is-active{% endif %}"
          {{ block.shopify_attributes }}
        >

          <div class="ab__content">

            {% if section.settings.show_icon %}
              <span class="ab__icon">
                {{ section.settings.icon }}
              </span>
            {% endif %}

            <div class="ab__text">
              {{ block.settings.text }}
            </div>

            {% if block.settings.button_label != blank %}

              <a
                href="{{ block.settings.button_link }}"
                class="ab__button"
              >
                {{ block.settings.button_label }}
              </a>

            {% endif %}

          </div>

        </div>

      {% endfor %}

    </div>

  {% endif %}

  {% if section.settings.show_close %}

    <button
      class="ab__close"
      aria-label="Close announcement bar"
    >
      ×
    </button>

  {% endif %}

</div>

  </div>

</section>

{% endif %}

{% schema %}
{
"name": "Premium Announcement Bar",
"tag": "section",
"class": "section-announcement-bar",
"settings": [
{
"type": "header",
"content": "Colors"
},
{
"type": "color",
"id": "background_color",
"label": "Background",
"default": "#676A26"
},
{
"type": "color",
"id": "text_color",
"label": "Text Color",
"default": "#F0EDD0"
},
{
"type": "color",
"id": "link_color",
"label": "Button Color",
"default": "#B54B3C"
},

{
  "type": "header",
  "content": "Typography"
},
{
  "type": "range",
  "id": "font_size_desktop",
  "label": "Desktop Font Size",
  "min": 10,
  "max": 24,
  "step": 1,
  "default": 12
},
{
  "type": "range",
  "id": "font_size_mobile",
  "label": "Mobile Font Size",
  "min": 10,
  "max": 20,
  "step": 1,
  "default": 11
},

{
  "type": "header",
  "content": "Spacing"
},
{
  "type": "range",
  "id": "height_desktop",
  "label": "Desktop Height",
  "min": 32,
  "max": 100,
  "step": 2,
  "default": 42
},
{
  "type": "range",
  "id": "height_mobile",
  "label": "Mobile Height",
  "min": 32,
  "max": 80,
  "step": 2,
  "default": 38
},
{
  "type": "range",
  "id": "padding_desktop",
  "label": "Desktop Padding",
  "min": 0,
  "max": 60,
  "step": 2,
  "default": 16
},
{
  "type": "range",
  "id": "padding_mobile",
  "label": "Mobile Padding",
  "min": 0,
  "max": 40,
  "step": 2,
  "default": 12
},

{
  "type": "header",
  "content": "Behavior"
},
{
  "type": "checkbox",
  "id": "sticky",
  "label": "Sticky",
  "default": false
},
{
  "type": "checkbox",
  "id": "show_close",
  "label": "Dismiss Button",
  "default": false
},
{
  "type": "checkbox",
  "id": "show_icon",
  "label": "Show Icon",
  "default": true
},
{
  "type": "text",
  "id": "icon",
  "label": "Icon / Emoji",
  "default": "✦"
},

{
  "type": "select",
  "id": "animation_style",
  "label": "Animation Style",
  "options": [
    {
      "value": "static",
      "label": "Static"
    },
    {
      "value": "slide",
      "label": "Slide / Rotate"
    },
    {
      "value": "marquee",
      "label": "Marquee"
    }
  ],
  "default": "static"
},

{
  "type": "checkbox",
  "id": "enable_autorotate",
  "label": "Auto Rotate",
  "default": true
},

{
  "type": "range",
  "id": "rotate_interval",
  "label": "Rotate Interval",
  "min": 3,
  "max": 15,
  "step": 1,
  "default": 5
},

{
  "type": "checkbox",
  "id": "enable_mobile",
  "label": "Show On Mobile",
  "default": true
},

{
  "type": "checkbox",
  "id": "enable_desktop",
  "label": "Show On Desktop",
  "default": true
},

{
  "type": "header",
  "content": "Scheduling"
},

{
  "type": "text",
  "id": "start_date",
  "label": "Start Date (YYYY-MM-DD)"
},

{
  "type": "text",
  "id": "end_date",
  "label": "End Date (YYYY-MM-DD)"
}

],

"blocks": [
{
"type": "message",
"name": "Announcement",
"settings": [
{
"type": "richtext",
"id": "text",
"label": "Message"
},
{
"type": "text",
"id": "button_label",
"label": "Button Label"
},
{
"type": "url",
"id": "button_link",
"label": "Button Link"
}
]
}
],

"presets": [
{
"name": "Premium Announcement Bar",
"blocks": [
{
"type": "message"
}
]
}
]
}
{% endschema %}
