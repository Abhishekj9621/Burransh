{%- if section.settings.enabled -%}
<div
  class="ann-bar ann-bar--{{ section.settings.color }}"
  id="annBar"
  data-mode="{{ section.settings.mode }}"
  aria-label="Announcement"
>
  <div class="ann-bar__inner">

    <div class="ann-bar__track-wrap">
      <div class="ann-bar__track" id="annTrack">

        {%- assign messages = section.settings.messages | split: '|' -%}

        {%- for msg in messages -%}
          <span class="ann-bar__msg">
            {%- if section.settings.link != blank -%}
              <a href="{{ section.settings.link }}">{{- msg | strip -}}</a>
            {%- else -%}
              {{- msg | strip -}}
            {%- endif -%}
          </span>
        {%- endfor -%}

        {%- if section.settings.mode == 'scroll' -%}
          {%- for msg in messages -%}
            <span class="ann-bar__msg" aria-hidden="true">
              {%- if section.settings.link != blank -%}
                <a href="{{ section.settings.link }}">{{- msg | strip -}}</a>
              {%- else -%}
                {{- msg | strip -}}
              {%- endif -%}
            </span>
          {%- endfor -%}
        {%- endif -%}

      </div>
    </div>

    {%- if section.settings.dismissible -%}
      <button class="ann-bar__close" id="annClose" aria-label="Close announcement">&#x2715;</button>
    {%- endif -%}

  </div>
</div>
{%- endif -%}

{% schema %}
{
  "name": "Announcement Bar",
  "settings": [
    {
      "type": "checkbox",
      "id": "enabled",
      "label": "Show announcement bar",
      "default": true
    },
    {
      "type": "textarea",
      "id": "messages",
      "label": "Messages — separate multiple with  |",
      "default": "Free Shipping Across India | New Arrivals — Spring Collection | Handcrafted in Uttarakhand"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Link (optional)"
    },
    {
      "type": "select",
      "id": "mode",
      "label": "Display mode",
      "options": [
        { "value": "scroll", "label": "Scrolling ticker" },
        { "value": "static", "label": "Static centered" }
      ],
      "default": "scroll"
    },
    {
      "type": "select",
      "id": "color",
      "label": "Bar colour",
      "options": [
        { "value": "forest", "label": "Forest green (default)" },
        { "value": "bark",   "label": "Dark bark" },
        { "value": "red",    "label": "Red — sale / urgent" }
      ],
      "default": "forest"
    },
    {
      "type": "checkbox",
      "id": "dismissible",
      "label": "Allow visitors to close the bar",
      "default": true
    }
  ]
}
{% endschema %}