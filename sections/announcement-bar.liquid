{{ 'announcement-bar.css' | asset_url | stylesheet_tag }}

{% liquid

assign show_section = true

if section.settings.homepage_only and request.page_type != 'index'
assign show_section = false
endif

%}

{% if show_section %}

<section
  class="announcement-bar {% if section.settings.sticky %}announcement-bar--sticky{% endif %}"
  style="
    background:{{ section.settings.background }};
    color:{{ section.settings.text_color }};
    --announcement-height:{{ section.settings.height }}px;
    --announcement-font-size:{{ section.settings.font_size }}px;
    border-bottom:
      {{ section.settings.border_width }}px
      solid
      {{ section.settings.border_color }};
  "
>

  <div class="announcement-bar__container">

```
<div class="announcement-marquee">

  <div class="announcement-marquee__track">

    {% for repeat in (1..6) %}

      {% for block in section.blocks %}

        {% if block.settings.link != blank %}
          <a
            href="{{ block.settings.link }}"
            class="announcement-marquee__item"
          >
        {% else %}
          <div class="announcement-marquee__item">
        {% endif %}

            {% if block.settings.show_icon %}

              <span class="announcement-marquee__icon">

                {% if block.settings.custom_icon != blank %}

                  {{
                    block.settings.custom_icon
                    | image_url: width: 40
                    | image_tag
                  }}

                {% else %}

                  ✦

                {% endif %}

              </span>

            {% endif %}

            <span>

              <span class="announcement-desktop">

                {{ block.settings.desktop_text }}

              </span>

              <span class="announcement-mobile">

                {% if block.settings.mobile_text != blank %}
                  {{ block.settings.mobile_text }}
                {% else %}
                  {{ block.settings.desktop_text }}
                {% endif %}

              </span>

            </span>

            <span class="announcement-marquee__divider">
              •
            </span>

        {% if block.settings.link != blank %}
          </a>
        {% else %}
          </div>
        {% endif %}

      {% endfor %}

    {% endfor %}

  </div>

</div>

  </div>

</section>

{% endif %}

{% schema %}
{
"name":"Luxury Announcement Bar",
"settings":[
{
"type":"checkbox",
"id":"sticky",
"label":"Sticky",
"default":false
},
{
"type":"checkbox",
"id":"homepage_only",
"label":"Homepage Only",
"default":false
},
{
"type":"range",
"id":"height",
"label":"Height",
"min":32,
"max":60,
"step":2,
"default":38
},
{
"type":"range",
"id":"font_size",
"label":"Font Size",
"min":9,
"max":16,
"step":1,
"default":11
},
{
"type":"color",
"id":"background",
"label":"Background",
"default":"#676A26"
},
{
"type":"color",
"id":"text_color",
"label":"Text Color",
"default":"#F0EDD0"
},
{
"type":"range",
"id":"border_width",
"label":"Border Width",
"min":0,
"max":5,
"step":1,
"default":1
},
{
"type":"color",
"id":"border_color",
"label":"Border Color",
"default":"#898C44"
}
],
"blocks":[
{
"type":"announcement",
"name":"Announcement",
"settings":[
{
"type":"text",
"id":"desktop_text",
"label":"Desktop Text",
"default":"Rooted In Culture. Worn Every Day."
},
{
"type":"text",
"id":"mobile_text",
"label":"Mobile Text"
},
{
"type":"url",
"id":"link",
"label":"Link"
},
{
"type":"checkbox",
"id":"show_icon",
"label":"Show Icon",
"default":true
},
{
"type":"image_picker",
"id":"custom_icon",
"label":"Custom Icon"
}
]
}
],
"presets":[
{
"name":"Luxury Announcement Bar"
}
]
}
{% endschema %}
