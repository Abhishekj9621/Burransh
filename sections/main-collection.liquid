{% comment %}
  BURANSHH — Main Collection Section
{% endcomment %}

<section class="collection-hero">
  <div class="container">
    <p class="collection-hero__eyebrow">{{ collection.products_count }} Pieces</p>
    <h1 class="collection-hero__title">{{ collection.title }}</h1>
    {%- if collection.description != blank -%}
      <div class="collection-hero__desc">{{ collection.description }}</div>
    {%- else -%}
      <p class="collection-hero__desc">Handcrafted pieces, made slowly and worn beautifully. Every item rooted in Himalayan craft, designed for everyday life.</p>
    {%- endif -%}
  </div>
</section>

<div class="collection-filters-bar">
  <div class="container collection-filters-bar__inner">
    <div class="filter-group">
      <span class="filter-label">Filter</span>
      <button class="filter-btn active" data-filter="all">All</button>
      <button class="filter-btn" data-filter="new">New</button>
      <button class="filter-btn" data-filter="sale">Sale</button>
    </div>
    <select class="sort-select" aria-label="Sort products" onchange="window.location.href=this.value">
      <option value="?sort_by=manual">Featured</option>
      <option value="?sort_by=best-selling">Best Selling</option>
      <option value="?sort_by=price-ascending">Price: Low to High</option>
      <option value="?sort_by=price-descending">Price: High to Low</option>
      <option value="?sort_by=created-descending">Newest</option>
    </select>
  </div>
</div>

<section class="featured-collection section-padding">
  <div class="container">
    <div class="product-grid" role="list">
      {%- if collection.products.size > 0 -%}
        {%- paginate collection.products by 16 -%}
          {%- for product in collection.products -%}
            {%- render 'product-card', product: product -%}
          {%- endfor -%}
        {%- endpaginate -%}
      {%- else -%}
        {%- for i in (1..8) -%}
          {%- render 'product-card-placeholder', index: i -%}
        {%- endfor -%}
      {%- endif -%}
    </div>

    {%- comment -%} Pagination {%- endcomment -%}
    {%- paginate collection.products by 16 -%}
      {%- if paginate.pages > 1 -%}
        <nav style="display:flex;justify-content:center;gap:8px;margin-top:64px;" aria-label="Pagination">
          {%- if paginate.previous -%}
            <a href="{{ paginate.previous.url }}" class="btn btn--outline">Previous</a>
          {%- endif -%}
          {%- for part in paginate.parts -%}
            {%- if part.is_link -%}
              <a href="{{ part.url }}" style="padding:10px 16px;font-size:13px;color:var(--color-text-muted);">{{ part.title }}</a>
            {%- else -%}
              <span style="padding:10px 16px;font-size:13px;color:var(--color-bark);font-weight:500;">{{ part.title }}</span>
            {%- endif -%}
          {%- endfor -%}
          {%- if paginate.next -%}
            <a href="{{ paginate.next.url }}" class="btn btn--outline">Next</a>
          {%- endif -%}
        </nav>
      {%- endif -%}
    {%- endpaginate -%}
  </div>
</section>

{% schema %}
{
  "name": "Collection Pages",
  "settings": []
}
{% endschema %}
