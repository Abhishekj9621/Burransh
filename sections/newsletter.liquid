{% comment %}
  BURANSHH — Newsletter Section
  Forest green background with email signup
{% endcomment %}

<section class="newsletter" aria-labelledby="nl-heading-{{ section.id }}">
  <div class="newsletter__circle newsletter__circle--1" aria-hidden="true"></div>
  <div class="newsletter__circle newsletter__circle--2" aria-hidden="true"></div>

  <div class="container">
    <div class="newsletter__inner">

      <div class="newsletter__content">
        {%- if section.settings.label != blank -%}
          <div class="section-label">{{ section.settings.label }}</div>
        {%- endif -%}
        <h2 id="nl-heading-{{ section.id }}" class="newsletter__heading">
          {{ section.settings.heading | default: 'Wear it before the world knows about it.' }}
        </h2>
        <p class="newsletter__body">{{ section.settings.body }}</p>
      </div>

      <div class="newsletter__form-wrap">
        {%- form 'customer', id: 'newsletter-form-{{ section.id }}', class: 'newsletter__form' -%}
          <input type="hidden" name="contact[tags]" value="newsletter">
          <input type="hidden" name="contact[accepts_marketing]" value="true">

          <div class="newsletter__input-group">
            <input
              type="email"
              name="contact[email]"
              id="newsletter-email-{{ section.id }}"
              class="newsletter__input"
              placeholder="{{ section.settings.placeholder | default: 'Your email address' }}"
              aria-label="Email address"
              required
              autocomplete="email"
            >
            <button type="submit" class="newsletter__submit" name="commit">
              {{ section.settings.button_label | default: 'Subscribe' }}
            </button>
          </div>

          {%- if form.posted_successfully? -%}
            <p style="font-size:12px;color:rgba(240,237,208,0.7);letter-spacing:0.08em;">
              ✓ &nbsp;Thank you for subscribing.
            </p>
          {%- endif -%}
          {%- if form.errors -%}
            <p style="font-size:12px;color:#f0a;letter-spacing:0.08em;" role="alert">
              {{ form.errors.translated_fields.email | capitalize }}
              {{ form.errors.messages.email }}
            </p>
          {%- endif -%}

          <p class="newsletter__note">
            {{ section.settings.note | default: 'No noise. Just new pieces and quiet stories.' }}
          </p>
        {%- endform -%}
      </div>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Newsletter",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Section label",
      "default": "Stay close"
    },
    {
      "type": "richtext",
      "id": "heading",
      "label": "Heading",
      "default": "<p>Wear it before<br>the world knows about it.</p>"
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Description",
      "default": "Early access to new collections. Behind-the-craft stories. The occasional quiet note from us."
    },
    {
      "type": "text",
      "id": "placeholder",
      "label": "Email placeholder",
      "default": "Your email address"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Subscribe"
    },
    {
      "type": "text",
      "id": "note",
      "label": "Privacy note",
      "default": "No noise. Just new pieces and quiet stories."
    }
  ],
  "presets": [
    {
      "name": "Newsletter"
    }
  ]
}
{% endschema %}
