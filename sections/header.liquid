{{ 'header.css' | asset_url | stylesheet_tag }}
<script src="{{ 'header.js' | asset_url }}" defer></script>

<header
  class="header
  {% if section.settings.sticky_header %}header--sticky{% endif %}
  {% if section.settings.transparent_header %}header--transparent{% endif %}
  {% if section.settings.show_border %}header--border{% endif %}"
  data-header-section
  style="
    --header-bg: {{ section.settings.background_color }};
    --header-text: {{ section.settings.text_color }};

    --header-container-width: {{ section.settings.container_width }}px;

    --header-height-desktop: {{ section.settings.header_height_desktop }}px;
    --header-height-mobile: {{ section.settings.header_height_mobile }}px;

    --header-logo-width-desktop: {{ section.settings.logo_width_desktop }}px;
    --header-logo-width-mobile: {{ section.settings.logo_width_mobile }}px;

    --header-menu-gap: {{ section.settings.menu_gap }}px;
  "
>

  <div class="header__container">

    <div class="header__inner">

      <!-- MOBILE TOGGLE -->

      <button
        class="header__toggle"
        data-header-toggle
        aria-label="Open menu"
      >

        <svg
          viewBox="0 0 24 24"
          fill="none"
        >
          <path
            d="M4 7H20"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
          />

          <path
            d="M4 12H20"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
          />

          <path
            d="M4 17H20"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
          />
        </svg>

      </button>

      <!-- LEFT NAV -->

      <nav
        class="header__nav-left"
        aria-label="Main navigation"
      >

        {% assign menu_links = linklists[section.settings.menu].links %}

        {% for link in menu_links limit:2 %}

          <a
            href="{{ link.url }}"
            class="header__link"
          >
            {{ link.title }}
          </a>

        {% endfor %}

      </nav>

      <!-- LOGO -->

      <div class="header__logo">

        <a
          href="{{ routes.root_url }}"
          class="header__logo-link"
        >

          {% if section.settings.logo != blank %}

            {{
              section.settings.logo
              | image_url: width: 600
              | image_tag:
                class: 'header__logo-image',
                loading: 'eager'
            }}

          {% else %}

            <span class="header__logo-text">
              {{ shop.name }}
            </span>

          {% endif %}

        </a>

      </div>

      <!-- RIGHT NAV -->

      <div class="header__nav-right">

        {% for link in menu_links offset:2 %}

          <a
            href="{{ link.url }}"
            class="header__link"
          >
            {{ link.title }}
          </a>

        {% endfor %}

        {% if section.settings.show_cta %}

          <a
            href="{{ section.settings.cta_link }}"
            class="header__cta"
          >
            {{ section.settings.cta_text }}
          </a>

        {% endif %}

        <div class="header__icons">

          {% if section.settings.show_search %}

            <a
              href="{{ routes.search_url }}"
              class="header__icon"
              aria-label="Search"
            >

              <svg
                viewBox="0 0 24 24"
                fill="none"
              >
                <circle
                  cx="11"
                  cy="11"
                  r="7"
                  stroke="currentColor"
                  stroke-width="1.5"
                />

                <path
                  d="M20 20L17 17"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                />
              </svg>

            </a>

          {% endif %}

          {% if section.settings.show_account %}

            <a
              href="{{ routes.account_url }}"
              class="header__icon"
              aria-label="Account"
            >

              <svg
                viewBox="0 0 24 24"
                fill="none"
              >
                <circle
                  cx="12"
                  cy="8"
                  r="4"
                  stroke="currentColor"
                  stroke-width="1.5"
                />

                <path
                  d="M5 20C5 16.5 8 14 12 14C16 14 19 16.5 19 20"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                />
              </svg>

            </a>

          {% endif %}

          {% if section.settings.show_cart %}

            <a
              href="{{ routes.cart_url }}"
              class="header__icon"
              aria-label="Cart"
            >

              <svg
                viewBox="0 0 24 24"
                fill="none"
              >
                <path
                  d="M6 7H20L18.5 15H8"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linejoin="round"
                />

                <circle
                  cx="9"
                  cy="19"
                  r="1"
                  fill="currentColor"
                />

                <circle
                  cx="17"
                  cy="19"
                  r="1"
                  fill="currentColor"
                />
              </svg>

              {% if cart.item_count > 0 %}

                <span class="header__cart-count">
                  {{ cart.item_count }}
                </span>

              {% endif %}

            </a>

          {% endif %}

        </div>

      </div>

    </div>

  </div>

  <!-- MOBILE DRAWER -->

  <div class="header-drawer">

    <button
      class="header-drawer__close"
      data-header-close
      aria-label="Close menu"
    >
      ×
    </button>

    <div class="header-drawer__inner">

      <nav class="header-drawer__nav">

        {% for link in menu_links %}

          <a
            href="{{ link.url }}"
            class="header-drawer__link"
          >
            {{ link.title }}
          </a>

        {% endfor %}

      </nav>

      <div class="header-drawer__bottom">

        {% if shop.customer_accounts_enabled %}

          <a
            href="{{ routes.account_url }}"
            class="header__link"
          >
            Account
          </a>

        {% endif %}

        <a
          href="{{ routes.search_url }}"
          class="header__link"
        >
          Search
        </a>

      </div>

    </div>

  </div>

</header>

{% schema %}
{
  "name": "Luxury Header",
  "tag": "section",
  "class": "section-header",
  "settings": [

    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },

    {
      "type": "link_list",
      "id": "menu",
      "label": "Menu"
    },

    {
      "type": "header",
      "content": "Logo"
    },

    {
      "type": "range",
      "id": "logo_width_desktop",
      "label": "Desktop Logo Width",
      "min": 80,
      "max": 300,
      "step": 10,
      "default": 180
    },

    {
      "type": "range",
      "id": "logo_width_mobile",
      "label": "Mobile Logo Width",
      "min": 60,
      "max": 200,
      "step": 10,
      "default": 120
    },

    {
      "type": "header",
      "content": "Layout"
    },

    {
      "type": "range",
      "id": "container_width",
      "label": "Container Width",
      "min": 1200,
      "max": 1800,
      "step": 50,
      "default": 1600
    },

    {
      "type": "range",
      "id": "header_height_desktop",
      "label": "Desktop Height",
      "min": 70,
      "max": 140,
      "step": 5,
      "default": 90
    },

    {
      "type": "range",
      "id": "header_height_mobile",
      "label": "Mobile Height",
      "min": 60,
      "max": 100,
      "step": 5,
      "default": 74
    },

    {
      "type": "range",
      "id": "menu_gap",
      "label": "Menu Gap",
      "min": 10,
      "max": 80,
      "step": 2,
      "default": 32
    },

    {
      "type": "checkbox",
      "id": "sticky_header",
      "label": "Sticky Header",
      "default": true
    },

    {
      "type": "checkbox",
      "id": "transparent_header",
      "label": "Transparent Header",
      "default": false
    },

    {
      "type": "checkbox",
      "id": "show_border",
      "label": "Show Border",
      "default": true
    },

    {
      "type": "header",
      "content": "Icons"
    },

    {
      "type": "checkbox",
      "id": "show_search",
      "label": "Show Search",
      "default": true
    },

    {
      "type": "checkbox",
      "id": "show_account",
      "label": "Show Account",
      "default": true
    },

    {
      "type": "checkbox",
      "id": "show_cart",
      "label": "Show Cart",
      "default": true
    },

    {
      "type": "header",
      "content": "CTA Button"
    },

    {
      "type": "checkbox",
      "id": "show_cta",
      "label": "Show CTA",
      "default": false
    },

    {
      "type": "text",
      "id": "cta_text",
      "label": "CTA Text",
      "default": "Shop Now"
    },

    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA Link"
    },

    {
      "type": "header",
      "content": "Colors"
    },

    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#FAF8EF"
    },

    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#3C3F14"
    }

  ],

  "presets": [
    {
      "name": "Luxury Header"
    }
  ]
}
{% endschema %}