{% liquid
  assign sticky_header = section.settings.sticky_header
  assign transparent_header = section.settings.transparent_header
%}

{% if section.settings.announcement_text != blank %}
<div class="announcement-bar">
  <div class="page-width">
    {{ section.settings.announcement_text }}
  </div>
</div>
{% endif %}

<header
  class="
    site-header
    {% if sticky_header %}site-header--sticky{% endif %}
    {% if transparent_header %}site-header--transparent{% endif %}
  "
>

  <div class="page-width">

    <div class="site-header__wrapper">

      <!-- MOBILE MENU -->
      <button
        class="site-header__mobile-toggle"
        aria-label="Open Menu"
        data-mobile-menu-trigger
      >
        <span></span>
        <span></span>
        <span></span>
      </button>

      <!-- NAVIGATION -->
      <nav class="site-header__nav">

        {% for link in section.settings.menu.links %}

          {% if link.links.size > 0 %}

            <div class="nav-item nav-item--has-dropdown">

              <a href="{{ link.url }}">
                {{ link.title }}
              </a>

              <div class="nav-dropdown">

                {% for childlink in link.links %}
                  <a href="{{ childlink.url }}">
                    {{ childlink.title }}
                  </a>
                {% endfor %}

              </div>

            </div>

          {% else %}

            <a href="{{ link.url }}">
              {{ link.title }}
            </a>

          {% endif %}

        {% endfor %}

      </nav>

      <!-- LOGO -->

      <a
        href="{{ routes.root_url }}"
        class="site-header__logo"
      >

        {% if section.settings.logo != blank %}

          {{
            section.settings.logo
            | image_url: width: section.settings.logo_width
            | image_tag:
              alt: shop.name,
              class: 'site-header__logo-image',
              loading: 'eager'
          }}

        {% else %}

          <span class="site-header__logo-text">
            {{ shop.name }}
          </span>

        {% endif %}

      </a>

      <!-- ACTIONS -->

      <div class="site-header__actions">

        {% if section.settings.show_search %}

          <button
            class="header-action"
            data-search-trigger
            aria-label="Search"
          >

            <svg viewBox="0 0 24 24">
              <circle cx="11" cy="11" r="7"></circle>
              <line x1="16" y1="16" x2="21" y2="21"></line>
            </svg>

          </button>

        {% endif %}

        {% if section.settings.show_wishlist %}

          <a
            href="/pages/wishlist"
            class="header-action"
            aria-label="Wishlist"
          >

            <svg viewBox="0 0 24 24">
              <path d="M12 21s-8-5.5-8-11a4.5 4.5 0 018-2.5A4.5 4.5 0 0120 10c0 5.5-8 11-8 11z"></path>
            </svg>

          </a>

        {% endif %}

        {% if section.settings.show_account %}

          <a
            href="{{ routes.account_url }}"
            class="header-action"
            aria-label="Account"
          >

            <svg viewBox="0 0 24 24">
              <circle cx="12" cy="8" r="4"></circle>
              <path d="M4 21a8 8 0 0116 0"></path>
            </svg>

          </a>

        {% endif %}

        {% if section.settings.show_cart %}

          <button
            class="header-action header-action--cart"
            data-cart-trigger
            aria-label="Cart"
          >

            <svg viewBox="0 0 24 24">
              <path d="M4 5h2l2.4 9h9.5l2.1-7H7"></path>
              <circle cx="10" cy="20" r="1"></circle>
              <circle cx="18" cy="20" r="1"></circle>
            </svg>

            <span class="cart-count">
              {{ cart.item_count }}
            </span>

          </button>

        {% endif %}

      </div>

    </div>

  </div>

</header>

{% schema %}
{
  "name": "Header",
  "class": "header-section",
  "settings": [
    {
      "type": "text",
      "id": "announcement_text",
      "label": "Announcement Text",
      "default": "Free Shipping on Orders Above ₹1,999"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "range",
      "id": "logo_width",
      "min": 80,
      "max": 300,
      "step": 10,
      "default": 140,
      "unit": "px",
      "label": "Logo Width"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Navigation Menu"
    },
    {
      "type": "checkbox",
      "id": "sticky_header",
      "label": "Enable Sticky Header",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "transparent_header",
      "label": "Enable Transparent Header",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_search",
      "label": "Show Search",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_wishlist",
      "label": "Show Wishlist",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_account",
      "label": "Show Account",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_cart",
      "label": "Show Cart",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Header"
    }
  ]
}
{% endschema %}