{{ 'section-header.css' | asset_url | stylesheet_tag }}

<header
  class="buranshh-header"
  data-section-id="{{ section.id }}"
>
  <div class="buranshh-header__container">

    <div class="buranshh-header__left desktop-only">
      {% for block in section.blocks %}
        {% if block.type == 'menu_link' %}
          <a
            href="{{ block.settings.link }}"
            class="buranshh-header__nav-link"
            {{ block.shopify_attributes }}
          >
            {{ block.settings.label }}
          </a>
        {% endif %}
      {% endfor %}
    </div>

    <div class="buranshh-header__mobile-toggle mobile-only">
      <button
        type="button"
        class="buranshh-header__menu-btn"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="mobile-menu-{{ section.id }}"
      >
        <span></span>
        <span></span>
      </button>
    </div>

    <div class="buranshh-header__logo">
      <a
        href="{{ routes.root_url }}"
        class="buranshh-header__logo-link"
        aria-label="{{ shop.name }}"
      >
        {% if section.settings.logo != blank %}
          {{
            section.settings.logo
            | image_url: width: 400
            | image_tag:
              widths: '120,180,240,320,400',
              loading: 'eager',
              class: 'buranshh-header__logo-image'
          }}
        {% else %}
          <span class="buranshh-header__logo-text">
            {{ shop.name }}
          </span>
        {% endif %}
      </a>
    </div>

    <div class="buranshh-header__right">

      {% if section.settings.enable_search %}
        <a
          href="{{ routes.search_url }}"
          class="buranshh-header__icon-link"
          aria-label="Search"
        >
          {% render 'icon-search' %}
        </a>
      {% endif %}

      <a
        href="{{ routes.account_url }}"
        class="buranshh-header__icon-link"
        aria-label="Account"
      >
        {% render 'icon-account' %}
      </a>

      <a
        href="{{ routes.cart_url }}"
        class="buranshh-header__icon-link"
        aria-label="Cart"
      >
        {% render 'icon-cart' %}
        <span class="buranshh-header__cart-count">
          {{ cart.item_count }}
        </span>
      </a>

    </div>

  </div>

  <div
    id="mobile-menu-{{ section.id }}"
    class="buranshh-mobile-menu"
  >
    <div class="buranshh-mobile-menu__inner">

      {% for block in section.blocks %}
        {% if block.type == 'menu_link' %}
          <a
            href="{{ block.settings.link }}"
            class="buranshh-mobile-menu__link"
            {{ block.shopify_attributes }}
          >
            {{ block.settings.label }}
          </a>
        {% endif %}
      {% endfor %}

    </div>
  </div>
</header>

<script src="{{ 'section-header.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Buranshh Header",
  "tag": "section",
  "class": "section-header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "checkbox",
      "id": "enable_search",
      "label": "Enable Search",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "menu_link",
      "name": "Menu Link",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Shop"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "max_blocks": 8,
  "presets": [
    {
      "name": "Buranshh Header"
    }
  ]
}
{% endschema %}