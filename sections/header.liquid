<header class="site-header" id="siteHeader">
  <div class="container">
    <div class="header-inner header-layout--{{ section.settings.logo_position }}">

      <a href="/" class="logo">
        {% if section.settings.logo %}
          <img
            src="{{ section.settings.logo | image_url: width: 400 }}"
            alt="{{ shop.name }}"
            loading="eager"
            height="56"
            width="auto"
          >
        {% else %}
          {{ shop.name | upcase }}
        {% endif %}
      </a>

      <nav class="desktop-nav" aria-label="Main navigation">
        {% assign nav_menu = linklists[section.settings.menu] %}
        {% for link in nav_menu.links %}
          {% if link.links != blank %}
            <div class="nav-item nav-item--dropdown">
              <button class="nav-dropdown-trigger" aria-expanded="false" aria-haspopup="true">
                {{ link.title }}
                <span class="nav-chevron" aria-hidden="true"></span>
              </button>
              <div class="nav-dropdown">
                {% for sub in link.links %}
                  <a class="nav-dropdown__link" href="{{ sub.url }}">{{ sub.title }}</a>
                {% endfor %}
              </div>
            </div>
          {% else %}
            <div class="nav-item">
              {% if link.active %}
                <a class="nav-link nav-link--active" href="{{ link.url }}" aria-current="page">{{ link.title }}</a>
              {% else %}
                <a class="nav-link" href="{{ link.url }}">{{ link.title }}</a>
              {% endif %}
            </div>
          {% endif %}
        {% endfor %}
      </nav>

      <div class="header-icons">
        {% if section.settings.show_search %}
          {% if section.settings.icon_style == 'icons' %}
            <a href="#" class="search-trigger header-icon-link" aria-label="Search">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
            </a>
          {% else %}
            <a href="#" class="search-trigger header-icon-link">Search</a>
          {% endif %}
        {% endif %}

        {% if section.settings.show_account %}
          {% if section.settings.icon_style == 'icons' %}
            <a href="/account" class="header-icon-link" aria-label="Account">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
            </a>
          {% else %}
            <a href="/account" class="header-icon-link">Account</a>
          {% endif %}
        {% endif %}

        {% if section.settings.icon_style == 'icons' %}
          <a href="#" class="cart-trigger header-icon-link" aria-label="Cart">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
            {% if cart.item_count > 0 %}
              <span class="cart-count">{{ cart.item_count }}</span>
            {% endif %}
          </a>
        {% else %}
          <a href="#" class="cart-trigger header-icon-link">
            Cart
            {% if cart.item_count > 0 %}
              <span class="cart-count">{{ cart.item_count }}</span>
            {% endif %}
          </a>
        {% endif %}
      </div>

      <button
        class="mobile-menu-btn"
        id="mobileMenuBtn"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="mobileMenu"
      >
        <span class="hamburger-line"></span>
        <span class="hamburger-line"></span>
        <span class="hamburger-line"></span>
      </button>

    </div>
  </div>
</header>

<nav class="mobile-menu" id="mobileMenu" aria-hidden="true">
  <div class="mobile-menu-inner">
    <button class="mobile-menu-close" id="closeMenu" aria-label="Close menu">&#x2715;</button>
    {% assign nav_menu = linklists[section.settings.menu] %}
    {% for link in nav_menu.links %}
      <a href="{{ link.url }}">{{ link.title }}</a>
    {% endfor %}
    <div class="mobile-menu-secondary">
      {% if section.settings.show_search %}
        <a href="#" class="search-trigger">Search</a>
      {% endif %}
      {% if section.settings.show_account %}
        <a href="/account">Account</a>
      {% endif %}
    </div>
  </div>
</nav>

{% if section.settings.show_search %}
<div class="search-modal" id="searchModal" role="dialog" aria-modal="true" aria-label="Search">
  <div class="search-inner">
    <form action="/search" method="get">
      <input
        type="search"
        name="q"
        id="searchInput"
        placeholder="Search Buranshh…"
        autocomplete="off"
        aria-label="Search"
      >
    </form>
    <p class="search-hint">Press Enter to search</p>
  </div>
  <button class="search-close" id="closeSearch">&#x2715; Close</button>
</div>
{% endif %}

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "header",
      "content": "Logo"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo image"
    },
    {
      "type": "select",
      "id": "logo_position",
      "label": "Logo position",
      "options": [
        { "value": "left",   "label": "Left (nav centre)" },
        { "value": "center", "label": "Centre (nav left)" },
        { "value": "split",  "label": "Split (logo centre, nav sides)" }
      ],
      "default": "left"
    },
    {
      "type": "header",
      "content": "Navigation"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Menu",
      "default": "main-menu"
    },
    {
      "type": "header",
      "content": "Icons"
    },
    {
      "type": "select",
      "id": "icon_style",
      "label": "Header icon style",
      "options": [
        { "value": "text",  "label": "Text labels" },
        { "value": "icons", "label": "SVG icons" }
      ],
      "default": "text"
    },
    {
      "type": "checkbox",
      "id": "show_search",
      "label": "Show search",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_account",
      "label": "Show account link",
      "default": true
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "select",
      "id": "header_border",
      "label": "Bottom border on scroll",
      "options": [
        { "value": "none",   "label": "None" },
        { "value": "line",   "label": "Thin line" },
        { "value": "shadow", "label": "Shadow (default)" }
      ],
      "default": "shadow"
    }
  ]
}
{% endschema %}