<section class="image-story section">

  <div class="container">

    <div class="image-story-grid">

      <div class="image-story-image">

        {% if section.settings.image %}
          {{
            section.settings.image
            | image_url: width: 1800
            | image_tag
          }}
        {% endif %}

      </div>

      <div class="image-story-content">

        <p class="section-label">
          {{ section.settings.label }}
        </p>

        <h2 class="section-title">
          {{ section.settings.heading }}
        </h2>

        <div class="image-story-text">
          {{ section.settings.text }}
        </div>

        {% if section.settings.button_text != blank %}
          <a
            href="{{ section.settings.button_link }}"
            class="btn-primary"
          >
            {{ section.settings.button_text }}
          </a>
        {% endif %}

      </div>

    </div>

  </div>

</section>

<style>

.image-story{
background:var(--parchment);
}

.image-story-grid{

display:grid;
grid-template-columns:55% 45%;
gap:80px;
align-items:center;

}

.image-story-image{

overflow:hidden;

}

.image-story-image img{

width:100%;
height:800px;
object-fit:cover;
transition:1s;

}

.image-story-image:hover img{

transform:scale(1.05);

}

.image-story-text{

font-size:18px;
line-height:1.9;
margin-bottom:40px;

}

@media(max-width:768px){

.image-story-grid{

grid-template-columns:1fr;

}

.image-story-image img{

height:500px;

}

}

</style>

{% schema %}
{
  "name":"Image Story",
  "settings":[

    {
      "type":"text",
      "id":"label",
      "label":"Label",
      "default":"Editorial"
    },

    {
      "type":"text",
      "id":"heading",
      "label":"Heading",
      "default":"Made For Real Life."
    },

    {
      "type":"richtext",
      "id":"text",
      "label":"Text"
    },

    {
      "type":"image_picker",
      "id":"image",
      "label":"Image"
    },

    {
      "type":"text",
      "id":"button_text",
      "label":"Button Text",
      "default":"Explore Collection"
    },

    {
      "type":"url",
      "id":"button_link",
      "label":"Button Link"
    }

  ],

  "presets":[
    {
      "name":"Image Story"
    }
  ]
}
{% endschema %}