<section class="brand-story section">

  <div class="container">

    <div class="brand-story-grid">

      <div class="brand-story-content">

        <p class="section-label">
          {{ section.settings.label }}
        </p>

        <h2 class="section-title">
          {{ section.settings.heading }}
        </h2>

        <div class="brand-story-text rte">
          {{ section.settings.text }}
        </div>

      </div>

      <div class="brand-story-image">

        {% if section.settings.image %}
          {{
            section.settings.image
            | image_url: width: 1400
            | image_tag: loading: 'lazy'
          }}
        {% else %}
          <div class="placeholder-image">
            Upload Image
          </div>
        {% endif %}

      </div>

    </div>

  </div>

</section>

<style>

.brand-story{
  padding:120px 0;
}

.brand-story-grid{
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:80px;
  align-items:center;
}

.brand-story-text{
  font-size:18px;
  line-height:1.8;
}

.brand-story-image img{
  width:100%;
  height:700px;
  object-fit:cover;
  display:block;
}

.placeholder-image{
  height:700px;
  background:#eee;
  display:flex;
  align-items:center;
  justify-content:center;
}

@media(max-width:768px){

  .brand-story-grid{
    grid-template-columns:1fr;
  }

  .brand-story-image img,
  .placeholder-image{
    height:500px;
  }

}

</style>

{% schema %}
{
  "name": "Brand Story",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Label",
      "default": "Our Story"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Rooted In Culture. Worn Every Day."
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Inspired by nature, handcrafted with intention, and designed for everyday elegance.</p>"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    }
  ],
  "presets": [
    {
      "name": "Brand Story"
    }
  ]
}
{% endschema %}