{% comment %}
  BURANSHH — Hero Section
  Customizable: image, heading, subheading, two CTA buttons, eyebrow text
{% endcomment %}

<section class="hero" aria-label="Hero banner">
  <div class="hero__bg{% if section.settings.image == blank %} hero__bg--dark{% endif %}">
    {%- if section.settings.image != blank -%}
      {%- assign hero_alt = section.settings.image.alt | default: shop.name -%}
      {{ section.settings.image | image_url: width: 2400
        | image_tag:
          loading: 'eager',
          fetchpriority: 'high',
          widths: '750, 1100, 1500, 1800, 2200',
          sizes: '100vw',
          alt: hero_alt
      }}
    {%- else -%}
      {%- comment -%} Placeholder background {%- endcomment -%}
      <div style="
        width:100%; height:100%;
        background: linear-gradient(135deg, #3C3F14 0%, #4F5222 40%, #676A26 100%);
      "></div>
    {%- endif -%}
  </div>

  <div class="container">
    <div class="hero__content" data-reveal>
      {%- if section.settings.eyebrow != blank -%}
        <p class="hero__eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h1 class="hero__heading">{{ section.settings.heading }}</h1>
      {%- endif -%}

      {%- if section.settings.subheading != blank -%}
        <p class="hero__subheading">{{ section.settings.subheading }}</p>
      {%- endif -%}

      <div class="hero__actions">
        {%- if section.settings.cta_primary_label != blank -%}
          <a href="{{ section.settings.cta_primary_url }}" class="btn btn--light">
            {{ section.settings.cta_primary_label }}
            <svg viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.2" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <path d="M1 7h12M8 2l5 5-5 5"/>
            </svg>
          </a>
        {%- endif -%}

        {%- if section.settings.cta_secondary_label != blank -%}
          <a href="{{ section.settings.cta_secondary_url }}" class="btn btn--ghost">
            {{ section.settings.cta_secondary_label }}
          </a>
        {%- endif -%}
      </div>
    </div>
  </div>

  <div class="hero__scroll" aria-hidden="true">
    <div class="hero__scroll-line"></div>
    <span class="hero__scroll-text">Scroll</span>
  </div>
</section>

{% schema %}
{
  "name": "Hero Banner",
  "tag": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "New Collection"
    },
    {
      "type": "richtext",
      "id": "heading",
      "label": "Heading",
      "default": "<p>Rooted in Culture.<br>Worn every day.</p>"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Handcrafted pieces inspired by the Himalayan landscape. Made slowly. Made to last."
    },
    {
      "type": "text",
      "id": "cta_primary_label",
      "label": "Primary CTA label",
      "default": "Shop the Collection"
    },
    {
      "type": "url",
      "id": "cta_primary_url",
      "label": "Primary CTA link"
    },
    {
      "type": "text",
      "id": "cta_secondary_label",
      "label": "Secondary CTA label",
      "default": "Our Story"
    },
    {
      "type": "url",
      "id": "cta_secondary_url",
      "label": "Secondary CTA link"
    },
    {
      "type": "range",
      "id": "min_height",
      "min": 50,
      "max": 100,
      "step": 5,
      "default": 90,
      "unit": "vh",
      "label": "Minimum height"
    }
  ],
  "presets": [
    {
      "name": "Hero Banner"
    }
  ]
}
{% endschema %}
