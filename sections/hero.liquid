<section class="hero">

<div class="hero-overlay"></div>

{% if section.settings.image %}
{{ section.settings.image
| image_url: width: 2500
| image_tag:
loading:'eager',
class:'hero-image'
}}
{% endif %}

<div class="hero-content container">

<p class="hero-eyebrow">
{{ section.settings.eyebrow }}
</p>

<h1>
{{ section.settings.heading }}
</h1>

<p class="hero-text">
{{ section.settings.text }}
</p>

<div class="hero-buttons">

<a
href="{{ section.settings.button_link }}"
class="btn-primary">
{{ section.settings.button_label }}
</a>

<a
href="{{ section.settings.button_link_2 }}"
class="btn-secondary">
{{ section.settings.button_label_2 }}
</a>

</div>

</div>

</section>

<style>

.hero{

position:relative;

height:100vh;

overflow:hidden;

display:flex;

align-items:center;

}

.hero-image{

position:absolute;

inset:0;

width:100%;

height:100%;

object-fit:cover;

}

.hero-overlay{

position:absolute;

inset:0;

background:rgba(0,0,0,.25);

z-index:1;
}

.hero-content{

position:relative;

z-index:2;

color:white;
}

.hero-eyebrow{

letter-spacing:.4em;

text-transform:uppercase;

margin-bottom:20px;
}

.hero h1{

font-size:110px;

max-width:800px;

line-height:1;
}

.hero-text{

max-width:600px;

margin-top:30px;

font-size:18px;
}

.hero-buttons{

display:flex;

gap:20px;

margin-top:40px;
}

@media(max-width:768px){

.hero h1{

font-size:56px;

}

.hero-buttons{

flex-direction:column;

}

}

</style>

{% schema %}
{
"name":"Hero",

"settings":[

{
"type":"image_picker",
"id":"image",
"label":"Hero Image"
},

{
"type":"text",
"id":"eyebrow",
"label":"Eyebrow",
"default":"Slow Fashion"
},

{
"type":"text",
"id":"heading",
"label":"Heading",
"default":"Bloom In Your Own Season"
},

{
"type":"textarea",
"id":"text",
"label":"Description"
},

{
"type":"text",
"id":"button_label",
"default":"Shop Collection",
"label":"Button Label"
},

{
"type":"url",
"id":"button_link",
"label":"Button Link"
},

{
"type":"text",
"id":"button_label_2",
"default":"Our Story",
"label":"Button Label 2"
},

{
"type":"url",
"id":"button_link_2",
"label":"Button Link 2"
}

],

"presets":[
{
"name":"Hero"
}
]
}
{% endschema %}