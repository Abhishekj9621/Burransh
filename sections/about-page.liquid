{% comment %}
  BURANSHH — About / Brand Story Page Section
{% endcomment %}

<section class="about-hero">
  <div class="container">
    <div class="about-hero__content" data-reveal>
      <div class="section-label">Our Story</div>
      <h1 class="about-hero__title">{{ section.settings.heading | default: 'Bloom in your own season.' }}</h1>
      <p class="about-hero__body">{{ section.settings.intro }}</p>
    </div>
  </div>
</section>

<section style="padding: var(--space-xl) 0;">
  <div class="container">
    <div class="brand-story__inner" style="grid-template-columns: 1fr 1fr;">
      <div>
        <div class="section-label">The Name</div>
        <h2 style="font-family:var(--font-serif);font-size:clamp(28px,3.5vw,40px);font-weight:300;color:var(--color-bark);margin-bottom:20px;line-height:1.2;">
          A wildflower from the Himalayas
        </h2>
        <p style="font-size:14px;color:var(--color-text-muted);line-height:1.95;max-width:480px;margin-bottom:24px;">
          Buransh is Uttarakhand's wildflower — bold red, mountain-born, culturally significant. The double 'h' in Buranshh is intentional: a visual pause, a breath, a softness layered into the name itself.
        </p>
        <p style="font-size:14px;color:var(--color-text-muted);line-height:1.95;max-width:480px;">
          Deeply inspired by the craft culture, terrain, and aesthetic of the Himalayas — not a brand tied to geography, but one that carries the spirit of that landscape in its ethos, palette, and making.
        </p>
      </div>
      <div class="brand-story__image-wrap">
        {%- if section.settings.story_image != blank -%}
          {{ section.settings.story_image | image_url: width: 900 | image_tag: loading: 'lazy', alt: 'Himalayan craft', style: 'width:100%;aspect-ratio:4/5;object-fit:cover;' }}
        {%- else -%}
          <div style="width:100%;aspect-ratio:4/5;background:var(--color-parchment);display:flex;align-items:center;justify-content:center;">
            <svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg" style="width:64px;height:64px;opacity:0.2;">
              <circle cx="32" cy="32" r="8" stroke="#676A26" stroke-width="1"/>
              <path d="M32 12C32 12 37 20 32 26C27 20 32 12 32 12Z" fill="#676A26" opacity="0.4"/>
            </svg>
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

<section style="padding: var(--space-xl) 0; background: var(--color-parchment);">
  <div class="container">
    <div style="text-align:center;margin-bottom:var(--space-lg);">
      <div class="section-label" style="justify-content:center;">What We Stand For</div>
      <h2 style="font-family:var(--font-serif);font-size:clamp(28px,3.5vw,44px);font-weight:300;color:var(--color-bark);">Six qualities, one filter</h2>
    </div>
    <div class="about-values-grid">
      {%- assign titles = 'Feminine|Quiet Luxury|Culturally Rooted|Everyday|Slow & Considered|Minimal' | split: '|' -%}
      {%- assign bodies = 'Not soft for the sake of softness — feminine in the sense of ease, intuition, and a knowing elegance that does not announce itself.|Quality implied, never shouted. Expressed through restraint — palette, spacing, typeface weight.|Indian craft is elevated, not explained. Cultural references are woven in subtly, not worn on the sleeve.|This is not occasionwear. Buranshh is for Tuesday mornings and Friday evenings alike.|Each piece is made with intention — unhurried, never trend-chasing, with a long view of beauty.|No clutter. No filler. White space is intentional. Every design element earns its place.' | split: '|' -%}
      {%- for title in titles -%}
        <div class="about-value-card">
          <div class="about-value-num">0{{ forloop.index }}</div>
          <h3 class="about-value-title">{{ title }}</h3>
          <p class="about-value-body">{{ bodies[forloop.index0] }}</p>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{%- render 'pull-quote-inline', quote: '"A clothing brand that captures the blend of nature-inspired handmade pieces with modern and expressive slow fashion."' -%}

<section style="padding: var(--space-xl) 0;">
  <div class="container">
    <div style="max-width:680px;">
      <div class="section-label">Our Mission</div>
      <h2 style="font-family:var(--font-serif);font-size:clamp(28px,3.5vw,42px);font-weight:300;color:var(--color-bark);margin-bottom:20px;line-height:1.2;">
        To uplift grassroots artisans
      </h2>
      <p style="font-size:14px;color:var(--color-text-muted);line-height:1.95;">
        Our mission is to bridge cultural craft with modern design, and build a brand that is as timeless as the landscape it draws from — one carefully curated piece at a time. We're working toward a future where Buranshh is a well-recognised name, with a growing team of designers, local artisans, and managers carrying this vision forward.
      </p>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "About Page",
  "settings": [
    {
      "type": "richtext",
      "id": "heading",
      "label": "Heading",
      "default": "<p>Bloom in your own season.</p>"
    },
    {
      "type": "textarea",
      "id": "intro",
      "label": "Intro text",
      "default": "Buranshh is a slow fashion clothing brand for women. Every piece is handcrafted, carefully curated, and designed to sit at the intersection of cultural craft and modern, everyday wearability."
    },
    {
      "type": "image_picker",
      "id": "story_image",
      "label": "Story image"
    }
  ]
}
{% endschema %}
