{% render 'pull-quote-inline',
  quote: section.settings.quote
%}

{% schema %}
{
  "name": "About Quote",
  "settings": [
    {
      "type": "textarea",
      "id": "quote",
      "label": "Quote",
      "default": "A clothing brand that captures the blend of nature-inspired handmade pieces with modern and expressive slow fashion."
    }
  ],
  "presets": [
    {
      "name": "About Quote"
    }
  ]
}
{% endschema %}