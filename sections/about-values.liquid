<section class="about-values">

  <div class="container">

    <div style="text-align:center">

      <div class="section-label">
        {{ section.settings.label }}
      </div>

      <h2>
        {{ section.settings.heading }}
      </h2>

    </div>

    <div class="about-values-grid">

      {% for block in section.blocks %}

        <div
          class="about-value-card"
          {{ block.shopify_attributes }}
        >

          <div class="about-value-num">
            {{ forloop.index }}
          </div>

          <h3>
            {{ block.settings.title }}
          </h3>

          <p>
            {{ block.settings.description }}
          </p>

        </div>

      {% endfor %}

    </div>

  </div>

</section>

{% schema %}
{
  "name": "About Values",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Label",
      "default": "What We Stand For"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Six qualities, one filter"
    }
  ],
  "blocks": [
    {
      "type": "value",
      "name": "Value",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "About Values",
      "blocks": [
        {
          "type": "value"
        },
        {
          "type": "value"
        },
        {
          "type": "value"
        }
      ]
    }
  ]
}
{% endschema %}