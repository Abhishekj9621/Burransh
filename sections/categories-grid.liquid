{% comment %}
  BURANSHH — Categories Grid Section
  Flexible grid of category cards with hover effects
{% endcomment %}

<section class="categories" aria-labelledby="cat-heading-{{ section.id }}">
  <div class="container">
    {%- if section.settings.title != blank -%}
      <div class="categories__header">
        {%- if section.settings.label != blank -%}
          <div class="section-label" style="justify-content:center;" aria-hidden="true">{{ section.settings.label }}</div>
        {%- endif -%}
        <h2 id="cat-heading-{{ section.id }}" class="categories__title">{{ section.settings.title }}</h2>
      </div>
    {%- endif -%}

    {%- assign layout = section.settings.layout -%}
    <div class="categories__grid{% if layout == '2-col' %} categories__grid--2{% endif %}">
      {%- for block in section.blocks -%}
        {%- if block.type == 'category' -%}
          {%- assign aspect = block.settings.aspect_ratio | default: 'tall' -%}
          <a href="{{ block.settings.link }}"
             class="category-card category-card--{{ aspect }}"
             {{ block.shopify_attributes }}
             aria-label="Shop {{ block.settings.name }}">

            {%- if block.settings.image != blank -%}
              {%- assign cat_alt = block.settings.image.alt | default: block.settings.name | escape -%}
              {{ block.settings.image | image_url: width: 900
                | image_tag:
                  class: 'category-card__bg',
                  loading: 'lazy',
                  widths: '500, 700, 900',
                  sizes: '(max-width: 900px) 100vw, 33vw',
                  alt: cat_alt
              }}
            {%- else -%}
              <div class="category-card__bg-placeholder" style="
                width:100%;height:100%;
                background: {% cycle '#676A26', '#4F5222', '#3C3F14', '#898C44', '#3C3F14', '#4F5222' %};
              "></div>
            {%- endif -%}

            <div class="category-card__overlay">
              <div class="category-card__content">
                {%- if block.settings.label != blank -%}
                  <p class="category-card__label">{{ block.settings.label }}</p>
                {%- endif -%}
                <h3 class="category-card__name">{{ block.settings.name }}</h3>
                <span class="category-card__link" aria-hidden="true">
                  Shop now
                  <span class="category-card__link-arrow"></span>
                </span>
              </div>
            </div>

          </a>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Categories Grid",
  "tag": "section",
  "max_blocks": 6,
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Section label",
      "default": "Shop by Category"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Section title",
      "default": "Find your everyday"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Grid layout",
      "options": [
        { "value": "3-col", "label": "3 columns" },
        { "value": "2-col", "label": "2 columns (featured)" }
      ],
      "default": "3-col"
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Eyebrow label",
          "default": "New in"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Category name",
          "default": "Everyday Kurtas"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "select",
          "id": "aspect_ratio",
          "label": "Card height",
          "options": [
            { "value": "tall", "label": "Tall (3:4)" },
            { "value": "square", "label": "Square (1:1)" },
            { "value": "wide", "label": "Wide (16:9)" }
          ],
          "default": "tall"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Categories Grid",
      "blocks": [
        { "type": "category", "settings": { "label": "Effortless comfort", "name": "Everyday Kurtas", "aspect_ratio": "tall" } },
        { "type": "category", "settings": { "label": "Artisan craft", "name": "Block Print", "aspect_ratio": "tall" } },
        { "type": "category", "settings": { "label": "Season's edit", "name": "Co-ords & Sets", "aspect_ratio": "tall" } }
      ]
    }
  ]
}
{% endschema %}
