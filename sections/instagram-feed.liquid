{% comment %}
  BURANSHH — Instagram Feed Section
  5-column grid, uses block images (manually curated, since no API)
{% endcomment %}

<section class="instagram-section" aria-labelledby="ig-heading-{{ section.id }}">
  <div class="container">
    <div class="instagram-section__header">
      <h2 id="ig-heading-{{ section.id }}" class="instagram-section__title">
        {{ section.settings.title | default: 'Worn, not staged' }}
      </h2>
      {%- if section.settings.handle != blank -%}
        <a href="https://instagram.com/{{ section.settings.handle | remove: '@' }}" target="_blank" rel="noopener" class="instagram-section__handle">
          {{ section.settings.handle }}
        </a>
      {%- endif -%}
    </div>

    <div class="instagram-grid">
      {%- for block in section.blocks -%}
        {%- if block.type == 'image' -%}
          <a href="{{ block.settings.link | default: '#' }}"
             class="instagram-item"
             {{ block.shopify_attributes }}
             target="_blank" rel="noopener"
             aria-label="View on Instagram">
            {%- if block.settings.image != blank -%}
              {{ block.settings.image | image_url: width: 500
                | image_tag:
                  loading: 'lazy',
                  widths: '250, 350, 500',
                  sizes: '20vw',
                  alt: 'Instagram post'
              }}
            {%- else -%}
              <div class="instagram-item__placeholder"></div>
            {%- endif -%}
            <div class="instagram-item__overlay">
              <svg class="instagram-item__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" xmlns="http://www.w3.org/2000/svg">
                <rect x="2" y="2" width="20" height="20" rx="5"/>
                <circle cx="12" cy="12" r="5"/>
              </svg>
            </div>
          </a>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Instagram Feed",
  "tag": "section",
  "max_blocks": 10,
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Worn, not staged"
    },
    {
      "type": "text",
      "id": "handle",
      "label": "Instagram handle",
      "default": "@buranshh"
    }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Instagram image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Post link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Instagram Feed",
      "blocks": [
        { "type": "image" },
        { "type": "image" },
        { "type": "image" },
        { "type": "image" },
        { "type": "image" }
      ]
    }
  ]
}
{% endschema %}
