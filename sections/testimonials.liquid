<section class="testimonials section">

<div class="container">

<p class="section-label">
{{ section.settings.label }}
</p>

<h2 class="section-title">
{{ section.settings.heading }}
</h2>

<div class="testimonial-grid">

{% for block in section.blocks %}

<div class="testimonial-card">

<div class="testimonial-quote">
“{{ block.settings.quote }}”
</div>

<div class="testimonial-name">
{{ block.settings.author }}
</div>

</div>

{% endfor %}

</div>

</div>

</section>

<style>

.testimonial-grid{

display:grid;

grid-template-columns:
repeat(3,1fr);

gap:30px;

}

.testimonial-card{

padding:40px;

background:white;

border:1px solid rgba(0,0,0,.05);

}

.testimonial-quote{

font-family:var(--heading);

font-size:32px;

line-height:1.4;

margin-bottom:30px;

}

.testimonial-name{

letter-spacing:.2em;

text-transform:uppercase;

font-size:12px;

}

@media(max-width:768px){

.testimonial-grid{

grid-template-columns:1fr;

}

}

</style>

{% schema %}
{
"name":"Testimonials",

"settings":[

{
"type":"text",
"id":"label",
"default":"Testimonials",
"label":"Label"
},

{
"type":"text",
"id":"heading",
"default":"Loved By Women Across India",
"label":"Heading"
}

],

"blocks":[

{
"type":"testimonial",

"name":"Testimonial",

"settings":[

{
"type":"textarea",
"id":"quote",
"label":"Quote"
},

{
"type":"text",
"id":"author",
"label":"Author"
}

]

}

],

"presets":[
{
"name":"Testimonials",
"blocks":[
{
"type":"testimonial"
},
{
"type":"testimonial"
},
{
"type":"testimonial"
}
]
}
]
}
{% endschema %}