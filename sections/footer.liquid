{% comment %}
  BURANSHH — Footer Section
{% endcomment %}

<footer class="site-footer" role="contentinfo">
  <div class="container">
    <div class="footer-top">

      {%- comment -%} Brand column {%- endcomment -%}
      <div class="footer-brand">
        <div class="footer-brand__logo">
          <div class="header-logo__mark" style="width:28px;height:28px;" aria-hidden="true">
            <svg viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg">
              <circle cx="9" cy="9" r="2" fill="#F0EDD0"/>
              <path d="M9 2C9 2 10.5 5 9 7C7.5 5 9 2 9 2Z" fill="#F0EDD0" opacity="0.7"/>
              <path d="M9 16C9 16 10.5 13 9 11C7.5 13 9 16 9 16Z" fill="#F0EDD0" opacity="0.7"/>
              <path d="M2 9C2 9 5 10.5 7 9C5 7.5 2 9 2 9Z" fill="#F0EDD0" opacity="0.7"/>
              <path d="M16 9C16 9 13 10.5 11 9C13 7.5 16 9 16 9Z" fill="#F0EDD0" opacity="0.7"/>
            </svg>
          </div>
          <span class="footer-brand__wordmark">{{ shop.name | default: 'Buranshh' }}</span>
        </div>

        <p class="footer-brand__tagline">
          {{ section.settings.tagline | default: '"Bloom in your own season."' }}
        </p>

        <p class="footer-brand__body">
          {{ section.settings.brand_body | default: 'Slow fashion for women. Rooted in Himalayan craft, designed for everyday life.' }}
        </p>

        <div class="footer-socials">
          {%- if section.settings.instagram != blank -%}
            <a href="{{ section.settings.instagram }}" class="footer-social" aria-label="Instagram" target="_blank" rel="noopener">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" xmlns="http://www.w3.org/2000/svg">
                <rect x="2" y="2" width="20" height="20" rx="5"/>
                <circle cx="12" cy="12" r="5"/>
                <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/>
              </svg>
            </a>
          {%- endif -%}
          {%- if section.settings.facebook != blank -%}
            <a href="{{ section.settings.facebook }}" class="footer-social" aria-label="Facebook" target="_blank" rel="noopener">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" xmlns="http://www.w3.org/2000/svg">
                <path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/>
              </svg>
            </a>
          {%- endif -%}
          {%- if section.settings.pinterest != blank -%}
            <a href="{{ section.settings.pinterest }}" class="footer-social" aria-label="Pinterest" target="_blank" rel="noopener">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" xmlns="http://www.w3.org/2000/svg">
                <path d="M12 2C6.48 2 2 6.48 2 12c0 4.24 2.65 7.86 6.39 9.29-.09-.78-.17-1.98.03-2.83.19-.75 1.26-5.35 1.26-5.35s-.32-.64-.32-1.59c0-1.49.87-2.6 1.94-2.6.92 0 1.36.69 1.36 1.51 0 .92-.59 2.3-.89 3.58-.25 1.07.53 1.94 1.58 1.94 1.9 0 3.17-2.4 3.17-5.24 0-2.16-1.46-3.77-4.1-3.77-2.99 0-4.85 2.23-4.85 4.72 0 .86.25 1.46.64 1.93.18.22.2.3.14.55-.05.18-.16.61-.2.78-.07.25-.27.34-.49.25-1.37-.56-2.01-2.07-2.01-3.76 0-2.8 2.36-6.17 7.04-6.17 3.78 0 6.29 2.75 6.29 5.7 0 3.91-2.17 6.85-5.37 6.85-1.07 0-2.09-.58-2.44-1.23l-.66 2.58c-.24.92-.88 2.08-1.32 2.78.99.31 2.05.47 3.14.47 5.52 0 10-4.48 10-10S17.52 2 12 2z"/>
              </svg>
            </a>
          {%- endif -%}
        </div>

        <div class="footer-payments" aria-label="Accepted payment methods">
          <!-- Payment icons will load via Shopify -->
          {%- for type in shop.enabled_payment_types -%}
            {{ type | payment_type_svg_tag: class: 'footer-payment-icon' }}
          {%- endfor -%}
        </div>
      </div>

      {%- comment -%} Link columns from blocks {%- endcomment -%}
      {%- for block in section.blocks -%}
        {%- if block.type == 'link_column' -%}
          <div class="footer-col" {{ block.shopify_attributes }}>
            <p class="footer-col__title">{{ block.settings.title }}</p>
            <ul class="footer-col__links">
              {%- if block.settings.menu != blank -%}
                {%- for link in block.settings.menu.links -%}
                  <li><a href="{{ link.url }}" class="footer-col__link">{{ link.title }}</a></li>
                {%- endfor -%}
              {%- endif -%}
            </ul>
          </div>
        {%- endif -%}
      {%- endfor -%}

    </div>

    {%- comment -%} Footer bottom bar {%- endcomment -%}
    <div class="footer-bottom">
      <p class="footer-bottom__copy">
        &copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved.
      </p>
      <nav class="footer-bottom__legal" aria-label="Legal links">
        {%- if section.settings.legal_menu != blank -%}
          {%- for link in section.settings.legal_menu.links -%}
            <a href="{{ link.url }}" class="footer-bottom__legal-link">{{ link.title }}</a>
          {%- endfor -%}
        {%- else -%}
          <a href="{{ routes.root_url }}pages/privacy-policy" class="footer-bottom__legal-link">Privacy Policy</a>
          <a href="{{ routes.root_url }}pages/refund-policy" class="footer-bottom__legal-link">Returns</a>
          <a href="{{ routes.root_url }}pages/shipping-policy" class="footer-bottom__legal-link">Shipping</a>
        {%- endif -%}
      </nav>
    </div>

  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "tag": "footer",
  "max_blocks": 3,
  "settings": [
    {
      "type": "text",
      "id": "tagline",
      "label": "Brand tagline",
      "default": "\"Bloom in your own season.\""
    },
    {
      "type": "textarea",
      "id": "brand_body",
      "label": "Brand description",
      "default": "Slow fashion for women. Rooted in Himalayan craft, designed for everyday life."
    },
    {
      "type": "header",
      "content": "Social links"
    },
    {
      "type": "url",
      "id": "instagram",
      "label": "Instagram URL"
    },
    {
      "type": "url",
      "id": "facebook",
      "label": "Facebook URL"
    },
    {
      "type": "url",
      "id": "pinterest",
      "label": "Pinterest URL"
    },
    {
      "type": "header",
      "content": "Legal links"
    },
    {
      "type": "link_list",
      "id": "legal_menu",
      "label": "Legal menu (optional)"
    }
  ],
  "blocks": [
    {
      "type": "link_column",
      "name": "Link column",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Column title",
          "default": "Shop"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Footer",
      "blocks": [
        { "type": "link_column", "settings": { "title": "Shop" } },
        { "type": "link_column", "settings": { "title": "Help" } },
        { "type": "link_column", "settings": { "title": "About" } }
      ]
    }
  ]
}
{% endschema %}
