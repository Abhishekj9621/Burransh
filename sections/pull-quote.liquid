{% comment %}
  BURANSHH — Pull Quote Section
  Centered editorial quote, used for brand voice moments
{% endcomment %}

<section style="padding: var(--space-lg) 0; background: {{ section.settings.background | default: '#FAF8EF' }};">
  <div class="container">
    <div style="max-width:720px;margin:0 auto;text-align:center;">
      <svg viewBox="0 0 40 30" style="width:32px;height:24px;margin:0 auto 24px;opacity:0.25;" fill="none" stroke="var(--color-forest)" stroke-width="1" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <path d="M8 4C4 8 2 13 2 18c0 4 3 8 7 8M28 4c-4 4-6 9-6 14 0 4 3 8 7 8"/>
      </svg>
      <p style="font-family:var(--font-serif);font-size:clamp(22px,3vw,32px);font-style:italic;font-weight:300;color:var(--color-bark);line-height:1.5;">
        {{ section.settings.quote | default: '"Buranshh doesn\'t sell clothes. It offers a way of getting dressed that feels like yourself."' }}
      </p>
      {%- if section.settings.attribution != blank -%}
        <p style="margin-top:20px;font-size:10px;letter-spacing:0.3em;text-transform:uppercase;color:var(--color-sage);">
          {{ section.settings.attribution }}
        </p>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Pull Quote",
  "tag": "section",
  "settings": [
    {
      "type": "textarea",
      "id": "quote",
      "label": "Quote",
      "default": "\"Buranshh doesn't sell clothes. It offers a way of getting dressed that feels like yourself.\""
    },
    {
      "type": "text",
      "id": "attribution",
      "label": "Attribution (optional)"
    },
    {
      "type": "color",
      "id": "background",
      "label": "Background color",
      "default": "#FAF8EF"
    }
  ],
  "presets": [
    {
      "name": "Pull Quote"
    }
  ]
}
{% endschema %}
