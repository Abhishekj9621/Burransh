{% comment %}
  BURANSHH — Featured Collection Section
  Shows products from a selected collection in a responsive grid
{% endcomment %}

{%- liquid
  assign collection = collections[section.settings.collection]
  assign products_to_show = section.settings.products_to_show | default: 8
  assign columns = section.settings.columns | default: 4
-%}

<section class="featured-collection section-padding" aria-labelledby="fc-heading-{{ section.id }}">
  <div class="container">

    <div class="featured-collection__header">
      <div>
        {%- if section.settings.label != blank -%}
          <div class="section-label" aria-hidden="true">{{ section.settings.label }}</div>
        {%- endif -%}
        <h2 id="fc-heading-{{ section.id }}" class="featured-collection__title">
          {{ section.settings.title | default: collection.title | default: 'New Arrivals' }}
        </h2>
        {%- if section.settings.subtitle != blank -%}
          <p class="featured-collection__subtitle">{{ section.settings.subtitle }}</p>
        {%- endif -%}
      </div>

      {%- if section.settings.show_view_all and collection != blank -%}
        <a href="{{ collection.url }}" class="btn btn--outline" aria-label="View all {{ collection.title }}">
          View All
          <svg viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.2" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M1 7h12M8 2l5 5-5 5"/>
          </svg>
        </a>
      {%- endif -%}
    </div>

    <div class="product-grid product-grid--{{ columns }}" role="list">
      {%- if collection != blank and collection.products_count > 0 -%}
        {%- for product in collection.products limit: products_to_show -%}
          {%- render 'product-card', product: product -%}
        {%- endfor -%}
      {%- else -%}
        {%- for i in (1..products_to_show) -%}
          {%- render 'product-card-placeholder', index: i -%}
        {%- endfor -%}
      {%- endif -%}
    </div>

  </div>
</section>

<style>
  .section-padding { padding: var(--space-xl) 0; }
</style>

{% schema %}
{
  "name": "Featured Collection",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Section label",
      "default": "New In"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Section title",
      "default": "New Arrivals"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Handcrafted pieces, made slowly and worn beautifully."
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 8,
      "label": "Products to show"
    },
    {
      "type": "select",
      "id": "columns",
      "label": "Columns (desktop)",
      "options": [
        { "value": "3", "label": "3 columns" },
        { "value": "4", "label": "4 columns" }
      ],
      "default": "4"
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "Show 'View all' button",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Featured Collection"
    }
  ]
}
{% endschema %}
