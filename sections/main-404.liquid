{% comment %}
  BURANSHH — 404 Page Section
{% endcomment %}

<section style="min-height:60vh;display:flex;align-items:center;justify-content:center;text-align:center;padding: var(--space-xl) var(--gutter);">
  <div>
    <p style="font-family:var(--font-serif);font-size:120px;font-weight:300;color:rgba(103,106,38,0.15);line-height:1;margin-bottom:8px;">404</p>
    <h1 style="font-family:var(--font-serif);font-size:clamp(28px,4vw,40px);font-style:italic;font-weight:300;color:var(--color-bark);margin-bottom:16px;">
      This page bloomed elsewhere.
    </h1>
    <p style="font-size:14px;color:var(--color-text-muted);margin-bottom:32px;max-width:420px;margin-left:auto;margin-right:auto;">
      The page you're looking for doesn't exist, or it has moved. Let's get you back to something beautiful.
    </p>
    <a href="{{ routes.root_url }}" class="btn btn--primary">Return Home</a>
  </div>
</section>

{% schema %}
{
  "name": "404 Page",
  "settings": []
}
{% endschema %}
